// Daily CAT — data model (multi-user)
// Postgres (Supabase) via Prisma. Every user has fully separate state:
// their own daily sets (generated at THEIR level), attempts, streak, SR queue.
// All "day" fields are IST calendar dates as "YYYY-MM-DD". Timestamps are UTC.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")      // Supabase pooled connection (pgbouncer, port 6543)
  directUrl = env("DIRECT_URL")        // Supabase direct connection (port 5432) — used by db:push/migrations
}

// Enums as validated strings:
// Section:      "QUANT" | "VARC" | "LRDI"
// Slot:         "MORNING" | "AFTERNOON" | "EVENING"
// SetStatus:    "READY" | "FALLBACK"
// ContextKind:  "RC_PASSAGE" | "LRDI_SCENARIO"
// QuestionKind: "MCQ" | "RC_PASSAGE_MCQ" | "PARA_JUMBLE" | "PARA_SUMMARY" | "ODD_ONE_OUT"

// A user account. The FIRST registered user becomes the admin.
// Passwords stored as scrypt salt:hash — never plaintext.
// LEVEL RULE: rolling avg of last 3 completed sets taken AT the current level;
// avg >= 75% → +1 (cap 10); < 40% → −1 (floor 1); fewer than 3 → no change.
// FREEZE RULE: one per calendar week, boundary = Monday 00:00 IST.
model User {
  id              String   @id @default(cuid())
  username        String   @unique
  passwordHash    String
  name            String
  isAdmin         Boolean  @default(false)
  createdAt       DateTime @default(now())

  levelQuant      Int     @default(1)
  levelVarc       Int     @default(1)
  levelLrdi       Int     @default(1)
  currentStreak   Int     @default(0)
  longestStreak   Int     @default(0)
  lastActiveDay   String?
  freezeAvailable Boolean @default(true)
  freezeResetWeek String?
  totalAnswered   Int     @default(0)
  totalCorrect    Int     @default(0)

  sets        QuestionSet[]
  attempts    SetAttempt[]
  answers     QuestionAttempt[]
  reviewItems ReviewItem[]
  dayLogs     DayLog[]
}

model QuestionSet {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          String
  section      String
  slot         String
  difficulty   Int       // the user's level when generated — frozen
  status       String    @default("READY")
  isFallback   Boolean   @default(false)
  generatedAt  DateTime  @default(now())
  model        String?
  promptTopics String    @default("[]") // JSON array — feeds the per-user 14-day no-repeat window

  contexts  ContextBlock[]
  questions Question[]
  attempt   SetAttempt?

  @@unique([day, section, userId])
  @@index([day])
}

// Shared context written ONCE (VARC passage / LRDI scenario), rendered above
// each question that references it. Question text is just the question.
model ContextBlock {
  id      String      @id @default(cuid())
  setId   String
  set     QuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  kind    String
  title   String
  body    String
  order   Int         @default(0)

  questions Question[]
}

model Question {
  id           String        @id @default(cuid())
  setId        String?
  set          QuestionSet?  @relation(fields: [setId], references: [id], onDelete: Cascade)
  contextId    String?
  context      ContextBlock? @relation(fields: [contextId], references: [id])
  isSeed       Boolean       @default(false)
  section      String
  difficulty   Int
  kind         String
  topic        String
  orderInSet   Int
  text         String
  options      String        // JSON array of exactly 4 strings
  correctIndex Int
  explanation  String
  verified     Boolean       @default(false)

  attempts   QuestionAttempt[]
  reviewItem ReviewItem?

  @@index([section, difficulty])
  @@index([topic])
}

model SetAttempt {
  id           String      @id @default(cuid())
  setId        String      @unique // sets are per-user, so one attempt per set still holds
  set          QuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime    @default(now())
  completedAt  DateTime?
  score        Int?
  totalTimeSec Int?
  levelBefore  Int
  levelAfter   Int?

  answers QuestionAttempt[]

  @@index([userId])
}

// Redo answers (isRedo, setAttemptId null) never touch DayLog or streak.
model QuestionAttempt {
  id           String      @id @default(cuid())
  questionId   String
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  setAttemptId String?
  setAttempt   SetAttempt? @relation(fields: [setAttemptId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRedo       Boolean     @default(false)
  chosenIndex  Int?
  isCorrect    Boolean?
  flagged      Boolean     @default(false)
  timeSpentSec Int?
  answeredAt   DateTime    @default(now())

  @@unique([setAttemptId, questionId])
  @@index([questionId])
  @@index([userId, isCorrect])
}

// Spaced repetition: stage → gap 0→1d, 1→3d, 2→7d, 3→21d; correct at 3 retires.
// Questions belong to per-user sets, so questionId stays unique.
model ReviewItem {
  id         String    @id @default(cuid())
  questionId String    @unique
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage      Int       @default(0)
  dueOn      String
  lapses     Int       @default(0)
  retiredAt  DateTime?

  @@index([userId, dueOn])
}

// Per-user per-day rollup → streaks + heatmap.
model DayLog {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  day               String
  sessionsCompleted Int     @default(0)
  questionsAnswered Int     @default(0)
  freezeUsed        Boolean @default(false)

  @@unique([day, userId])
}

// Generation lock, now per user: unique (day, section, userId).
model GenerationJob {
  id         String    @id @default(cuid())
  day        String
  section    String
  userId     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    @default("RUNNING") // "RUNNING" | "SUCCESS" | "FAILED"
  error      String?

  @@unique([day, section, userId])
}
