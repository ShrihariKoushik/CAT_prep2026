# Supabase → Project Settings → Database → Connection string
# DATABASE_URL: "Transaction" mode (pooler, port 6543) — add ?pgbouncer=true
# DIRECT_URL:   "Session"/direct mode (port 5432) — used only by db:push
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# Server-side only — never exposed to the client.
ANTHROPIC_API_KEY="sk-ant-..."

# Shared secret protecting /api/cron/generate and /api/admin/reset.
CRON_SECRET="generate-a-long-random-string"

# Signs session cookies. Falls back to CRON_SECRET if unset.
AUTH_SECRET="another-long-random-string"

# Gates the /admin portal. Anyone with this password can view all users' stats.
ADMIN_PASSWORD="AdminCat2026"
